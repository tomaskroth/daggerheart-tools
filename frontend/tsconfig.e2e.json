{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./e2e-dist",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": ["e2e/**/*.ts"],
  "exclude": ["node_modules"]
}
